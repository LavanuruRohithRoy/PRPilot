# Database Configuration
# Main application PostgreSQL connection URL (using asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prpilot

# GitHub Integration Config
# Personal Access Token (PAT) used to call GitHub APIs
GITHUB_TOKEN=your-github-token-here
# GitHub webhook secret token used to verify event signature headers
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# Fallback/base URL of the GitHub API endpoint
GITHUB_API_URL=https://api.github.com

# Microsoft AI Foundry / Azure OpenAI Config
# Azure AI Foundry Project workspace connection string (Entra ID flow fallback)
AZURE_AI_FOUNDRY_CONNECTION_STRING=your-foundry-connection-string-here
# Direct Azure OpenAI endpoint URL (e.g. https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# Azure OpenAI service authentication key (API key)
AZURE_OPENAI_API_KEY=your-api-key-here
# Name of the model deployment hosted on Azure OpenAI (e.g. gpt-4o)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
